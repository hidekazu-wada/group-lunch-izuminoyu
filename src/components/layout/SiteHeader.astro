    <div class="site-header__actions">
      <a
        class="site-header__cta site-header__cta--tel c-btn c-btn--tel"
        href={SITE.telHref}
        data-ga-event="tel_tap"
        data-ga-label="header"
      >
        <span class="c-btn__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </span>
        <span class="site-header__cta-text">お電話｜{SITE.tel}</span>
      </a>

      <a
        class="site-header__cta site-header__cta--form c-btn c-btn--form"
        href="#contact"
      >
        <span class="c-btn__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16v12H7l-3 3V4z"></path>
          </svg>
        </span>
        <span class="site-header__cta-text">問い合わせフォーム</span>
      </a>
    </div>
  </div>
</header>

<script>
  // Hero を抜けたら背景を出す（state: top → scrolled）
  const header = document.getElementById('site-header');
  const hero = document.getElementById('hero');

  if (header && hero) {
    // Hero の下端が画面上端を越えたら scrolled に
    const io = new IntersectionObserver(
      ([entry]) => {
        header.dataset.state = entry.isIntersecting ? 'top' : 'scrolled';
      },
      { rootMargin: '-80px 0px 0px 0px', threshold: 0 }
    );
    io.observe(hero);
  } else if (header) {
    // Hero が無い場合は常に scrolled
    header.dataset.state = 'scrolled';
  }
</script>

<style lang="scss">
  @import "../../styles/variables";
  @import "../../styles/functions";
  @import "../../styles/mixins";

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%; // 100vw不可（fixed幅とスクロールバー幅の食い違い回避）
    z-index: 200; // 各セクションより前面に常時表示
    transition:
      background-color var(--dur-base) var(--ease-soft),
      box-shadow var(--dur-base) var(--ease-soft),
      color var(--dur-base) var(--ease-soft);

    // 初期：Hero上に透明で重なる。ロゴはクリームで写真上に視認
    &[data-state="top"] {
      background-color: transparent;
      color: var(--main_color_3);

      .site-header__parent {
        text-shadow: 0 1px 6px rgba(28, 20, 14, 0.5);
      }

      .site-header__logo {
        filter: drop-shadow(0 1px 6px rgba(28, 20, 14, 0.45));
      }
    }

    // スクロール後：クリーム背景＋影。ロゴはブラウン
    &[data-state="scrolled"] {
      background-color: rgba(241, 234, 228, 0.95);
      backdrop-filter: blur(8px);
      box-shadow: 0 2px 16px rgba(124, 99, 81, 0.16);
      color: var(--main_color_1);
    }
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: clamp(8px, 1.4vw, 14px);
  }

  // ---- ブランド（ロゴ＋母体名） ----
  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: inherit;
    min-width: 0;
  }

  .site-header__logo {
    display: inline-flex;
    flex-shrink: 0;
    // viewBox 262:109 ≒ 2.4:1。高さ基準でサイズ指定
    height: clamp(34px, 5vw, 48px);

    svg {
      display: block;
      height: 100%;
      width: auto;
      fill: currentColor;
    }
  }

  // ---- CTA（電話＋フォーム） ----
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  // .c-btn の min-height:64px / width:100% を上書きしてヘッダー用にコンパクト化
  .site-header__cta {
    width: auto;
    min-height: 0;
    padding-block: clamp(6px, 1vw, 10px);
    padding-inline: clamp(12px, 1.6vw, 20px);
    font-size: var(--fs-meta);
  }

  .site-header__cta .c-btn__icon {
    width: 1.1em;
    height: 1.1em;

    svg {
      display: block;
      width: 100%;
      height: 100%;
    }
  }

  // SP：テキストを隠し、アイコンのみの小さな円形ボタンに（2つ並べてもスッキリ）
  @media (max-width: 600px) {
    .site-header__cta-text {
      display: none;
    }

    .site-header__cta {
      width: clamp(38px, 11vw, 44px);
      height: clamp(38px, 11vw, 44px);
      padding: 0;
      border-radius: 50%;
    }

    .site-header__cta .c-btn__icon {
      width: 45%;
      height: 45%;
    }

    .site-header__actions {
      gap: var(--space-2);
    }
  }
</style>

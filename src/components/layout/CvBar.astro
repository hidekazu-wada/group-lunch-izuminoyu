---
// スマホ追従CVバー（電話 / フォーム）。tablet-up で非表示
import { SITE } from '../../consts';
---

<div class="cv-bar" role="region" aria-label="お問い合わせ">
  <a
    class="cv-bar__btn cv-bar__btn--tel"
    href={SITE.telHref}
    data-ga-event="tel_tap"
    data-ga-label="cvbar"
  >
    <span class="cv-bar__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
    </span>
    <span class="cv-bar__txt">
      <span class="cv-bar__label">お電話で相談</span>
      <span class="cv-bar__num">{SITE.tel}</span>
    </span>
  </a>

  <a class="cv-bar__btn cv-bar__btn--form" href="#contact">
    <span class="cv-bar__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h16v12H7l-3 3V4z"></path>
      </svg>
    </span>
    <span class="cv-bar__txt">
      <span class="cv-bar__label">フォームで</span>
      <span class="cv-bar__num">問い合わせ</span>
    </span>
  </a>
</div>

<style lang="scss">
  @import "../../styles/variables";
  @import "../../styles/functions";
  @import "../../styles/mixins";

  .cv-bar {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 100;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: spx(8);
    height: var(--cv-bar-h);
    padding: spx(8) spx(12) calc(#{spx(8)} + env(safe-area-inset-bottom));
    background-color: rgba(241, 234, 228, 0.95);
    backdrop-filter: blur(6px);
    box-shadow: 0 -4px 20px rgba(124, 99, 81, 0.18);

    @include tablet-up {
      display: none;
    }
  }

  .cv-bar__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: spx(8);
    border-radius: var(--radius-pill);
    font-weight: 700;
    line-height: 1.2;

    &--tel {
      background-color: var(--main_color_2);
      color: var(--main_color_1);
    }

    &--form {
      background-color: var(--main_color_1);
      color: var(--main_color_3);
    }
  }

  .cv-bar__icon {
    width: spx(36);
    height: spx(36);
    flex-shrink: 0;

    svg {
      width: 100%;
      height: 100%;
    }
  }

  .cv-bar__txt {
    display: flex;
    flex-direction: column;
  }

  .cv-bar__label {
    font-size: spx(20);
    font-weight: 500;
  }

  .cv-bar__num {
    font-size: spx(26);
    font-weight: 700;
  }
</style>

---
// 中盤CTAバンド（FV・最後に加えて「中盤」のCTA動線）
import { SITE } from '../../consts';
---

<section class="cta-band l-section l-section--brown" aria-label="お問い合わせのご案内">
  <div class="l-container cta-band__inner">
    <p class="cta-band__lead">団体のご予約・お見積りは、お気軽にご相談ください。</p>
    <div class="cta-band__cta c-cta">
      <a
        class="c-btn c-btn--tel"
        href={SITE.telHref}
        data-ga-event="tel_tap"
        data-ga-label="midband"
      >
        <span class="c-btn__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </span>
        お電話で相談｜{SITE.tel}
      </a>
      <a class="c-btn c-btn--ghost" href="#contact">問い合わせフォーム</a>
    </div>
  </div>
</section>

<style lang="scss">
  @import "../../styles/variables";
  @import "../../styles/functions";
  @import "../../styles/mixins";

  // バンドなのでセクションより余白は控えめに
  .cta-band {
    padding-block: var(--space-5);

    @include desktop-up {
      padding-block: var(--space-6);
    }
  }

  .cta-band__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
  }

  .cta-band__lead {
    font-size: var(--fs-h3);
    font-weight: 700;
    line-height: var(--lh-tight);
  }

  .cta-band__cta {
    width: 100%;

    @include tablet-up {
      width: auto;
    }
  }
</style>

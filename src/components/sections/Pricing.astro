---
// ⑨ ご利用案内・料金
// 貸切利用料の料金表。SPはカード型、tablet-up以上はテーブル型に組み替える
import { SITE } from '../../consts';
---

<section class="l-section l-section--cream pricing" id="pricing">
  <div class="l-container">
    <div class="c-head">
      <p class="c-head__label">PRICE</p>
      <h2 class="c-head__title">ご利用案内</h2>
    </div>

    <!-- 料金表（貸切利用料） -->
    <div class="pricing__table" role="table" aria-label="貸切利用料">
      <div class="pricing__row pricing__row--head" role="row">
        <span class="pricing__cell pricing__cell--use" role="columnheader">ご利用</span>
        <span class="pricing__cell pricing__cell--time" role="columnheader">滞在時間</span>
        <span class="pricing__cell pricing__cell--price" role="columnheader">お一人さま</span>
        <span class="pricing__cell pricing__cell--min" role="columnheader">最低保証</span>
      </div>

      <div class="pricing__row" role="row">
        <span class="pricing__cell pricing__cell--use" role="cell">
          <span class="pricing__label" aria-hidden="true">ご利用</span>休憩
        </span>
        <span class="pricing__cell pricing__cell--time" role="cell">
          <span class="pricing__label" aria-hidden="true">滞在時間</span>2時間
        </span>
        <span class="pricing__cell pricing__cell--price" role="cell">
          <span class="pricing__label" aria-hidden="true">お一人さま</span>800円
        </span>
        <span class="pricing__cell pricing__cell--min" role="cell">
          <span class="pricing__label" aria-hidden="true">最低保証</span>30,000円
        </span>
      </div>

      <div class="pricing__row pricing__row--featured" role="row">
        <span class="pricing__badge">おすすめ</span>
        <span class="pricing__cell pricing__cell--use" role="cell">
          <span class="pricing__label" aria-hidden="true">ご利用</span>体験／お食事・ご入浴
        </span>
        <span class="pricing__cell pricing__cell--time" role="cell">
          <span class="pricing__label" aria-hidden="true">滞在時間</span>2＋1時間
        </span>
        <span class="pricing__cell pricing__cell--price" role="cell">
          <span class="pricing__label" aria-hidden="true">お一人さま</span><strong>500円</strong>
        </span>
        <span class="pricing__cell pricing__cell--min" role="cell">
          <span class="pricing__label" aria-hidden="true">最低保証</span>30,000円
        </span>
      </div>

      <div class="pricing__row" role="row">
        <span class="pricing__cell pricing__cell--use" role="cell">
          <span class="pricing__label" aria-hidden="true">ご利用</span>延長
        </span>
        <span class="pricing__cell pricing__cell--time" role="cell">
          <span class="pricing__label" aria-hidden="true">滞在時間</span>1時間ごと
        </span>
        <span class="pricing__cell pricing__cell--price" role="cell">
          <span class="pricing__label" aria-hidden="true">お一人さま</span>400円
        </span>
        <span class="pricing__cell pricing__cell--min" role="cell">
          <span class="pricing__label" aria-hidden="true">最低保証</span>—
        </span>
      </div>
    </div>

    <!-- 料金表の注記（用語補足＋ダミー注記） -->
    <div class="pricing__notes">
      <p class="c-note">
        ※「最低保証」は、ご利用人数が少ない場合の貸切1組あたりの下限料金です。
      </p>
      {/* 🔴 料金・滞在時間・最低保証・提供時間帯・営業日 未確定（確定後に差し替え） */}
      <p class="c-note">
        ※料金・滞在時間・提供時間帯・営業日は、確定しだいご案内します。
      </p>
    </div>

    <!-- ポイント -->
    <div class="pricing__point c-card">
      <p class="pricing__point-text">
        お食事・ご入浴をご利用の場合は、貸切利用料がお一人さま500円に。滞在時間も1時間延長してゆっくりお過ごしいただけます。
      </p>
      <p class="pricing__point-text pricing__point-text--ex">
        （例：カレーライスご利用 1,100円＋貸切利用料500円＝<strong>お一人さま1,600円・税込</strong>）
      </p>
    </div>

    <!-- 表直後の軽量CTA（料金に納得した瞬間に相談へ） -->
    <div class="pricing__cta">
      <p class="pricing__cta-lead">人数・ご予算に合わせて、お見積りします。</p>
      <div class="c-cta">
        <a
          class="c-btn c-btn--tel"
          href={SITE.telHref}
          data-ga-event="tel_tap"
          data-ga-label="pricing"
        >
          <span class="c-btn__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </span>
          お電話で相談｜{SITE.tel}
        </a>
        <a class="c-btn c-btn--form" href="#contact">問い合わせフォーム</a>
      </div>
    </div>

    <!-- ご利用条件 -->
    <div class="pricing__terms">
      <h3 class="pricing__terms-title">ご利用条件</h3>
      <ul class="pricing__terms-list">
        <li class="pricing__terms-item">
          団体予約制（事前のお問い合わせをお願いします）
        </li>
        <!-- 🔴 人数下限/提供時間帯/営業日 未確定（ダミー） -->
        <li class="pricing__terms-item">
          ご利用人数の目安：{SITE.capacityMin}名〜{SITE.capacityMax}名／提供時間帯：{SITE.openHours}／営業日：{SITE.openDays}
        </li>
        <li class="pricing__terms-item">
          貸切利用・お土産の手配は、事前のご予約が必要です
        </li>
      </ul>
    </div>
  </div>
</section>

<style lang="scss">
  @import "../../styles/variables";
  @import "../../styles/functions";
  @import "../../styles/mixins";

  // ---- 料金表（SP＝カード型 / tablet-up＝テーブル型） ----------
  .pricing__table {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .pricing__row {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border-radius: var(--radius-card);
    background-color: var(--white);
    box-shadow: var(--shadow-soft);
  }

  // おすすめ行のハイライト
  .pricing__row--featured {
    background-color: var(--main_color_3);
    box-shadow: var(--shadow-card);
    border: 2px solid var(--main_color_2);
  }

  // SPでは見出し行（テーブル用ヘッダ）を隠す。
  // .pricing__row の display:flex に勝つよう詳細度を上げる
  .pricing__table .pricing__row--head {
    display: none;
  }

  .pricing__badge {
    position: absolute;
    top: 0;
    right: var(--space-3);
    transform: translateY(-50%);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    background-color: var(--main_color_2);
    color: var(--main_color_1);
    font-size: var(--fs-meta);
    font-weight: 700;
    line-height: 1.4;
    white-space: nowrap;
  }

  .pricing__cell {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--main_color_1);
  }

  // SPカード内の項目ラベル
  .pricing__label {
    flex-shrink: 0;
    min-width: 7em;
    font-size: var(--fs-meta);
    font-weight: 500;
    opacity: 0.7;
  }

  // 価格セルは数字を少し強調（おすすめ行の500円はstrong）
  .pricing__cell--price {
    font-weight: 700;
  }

  // ---- tablet-up：テーブル組み（4カラム） ---------------------
  @include tablet-up {
    .pricing__table {
      gap: 0;
      border-radius: var(--radius-card);
      overflow: clip; // 角丸内に行をクリップ
      box-shadow: var(--shadow-soft);
    }

    .pricing__row {
      flex-direction: row;
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-4) var(--space-5);
      border-radius: 0;
      box-shadow: none;
      border-bottom: 1px solid rgba(124, 99, 81, 0.12);
    }

    // tablet-up で見出し行を再表示（SPの隠し指定と詳細度を揃える）
    .pricing__table .pricing__row--head {
      display: flex;
      background-color: var(--main_color_1);
    }

    .pricing__row--head .pricing__cell {
      font-size: var(--fs-meta);
      font-weight: 700;
      color: var(--main_color_3);
    }

    .pricing__row:last-child {
      border-bottom: none;
    }

    .pricing__row--featured {
      border: none;
      box-shadow: inset 0 0 0 2px var(--main_color_2);
    }

    // テーブル時：右端の数値（最低保証）と被るため、行の左上隅へ移す
    .pricing__badge {
      top: 0;
      right: auto;
      left: var(--space-5);
      transform: translateY(-50%);
    }

    // テーブル時はカード内ラベルを隠す
    .pricing__label {
      display: none;
    }

    .pricing__cell {
      flex: 1 1 0;
    }

    .pricing__cell--use {
      flex: 1.6 1 0;
    }
  }

  @include desktop-up {
    .pricing__row {
      padding: var(--space-4) var(--space-6);
    }

    // 行paddingの拡大に合わせてバッジ位置も揃える
    .pricing__badge {
      left: var(--space-6);
    }
  }

  // ---- 料金表の注記 -------------------------------------------
  .pricing__notes {
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  // ---- ポイント（おすすめ訴求カード） -------------------------
  .pricing__point {
    margin-top: var(--space-5);
  }

  .pricing__point-text {
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    color: var(--main_color_1);

    & + & {
      margin-top: var(--space-2);
    }
  }

  .pricing__point-text--ex {
    color: var(--blue_1);
  }

  // ---- 表直後CTA（軽量） -------------------------------------
  .pricing__cta {
    margin-top: var(--space-5);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
  }

  .pricing__cta-lead {
    font-size: var(--fs-h3);
    font-weight: 700;
    line-height: var(--lh-tight);
    color: var(--main_color_1);
  }

  // CTAボタン：SPは全幅、tablet-up以上は内容幅（CtaBandと挙動を揃える）
  .pricing__cta .c-cta {
    width: 100%;

    @include tablet-up {
      width: auto;
    }
  }

  // ---- ご利用条件 --------------------------------------------
  .pricing__terms {
    margin-top: var(--space-5);
  }

  .pricing__terms-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    line-height: var(--lh-tight);
    color: var(--main_color_1);
    margin-bottom: var(--space-3);
  }

  .pricing__terms-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pricing__terms-item {
    position: relative;
    padding-left: var(--space-4);
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    color: var(--main_color_1);

    &::before {
      content: "";
      position: absolute;
      top: 0.7em;
      left: 0;
      width: 0.5em;
      height: 0.5em;
      border-radius: var(--radius-pill);
      background-color: var(--main_color_2);
    }
  }
</style>

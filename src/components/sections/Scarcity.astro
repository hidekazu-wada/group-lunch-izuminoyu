---
// ② 希少性（つかみ）— PAS：手配者の痛みに共感 → いずみの湯ならまるごと解決
import { SITE } from "../../consts";
import { Image } from "astro:assets";
import crowdBusy from "../../assets/images/scarcity/crowd_busy.png";
import privateLakeside from "../../assets/images/scarcity/private_lakeside.png";

// 手配者の“段取り”の痛み（共感）
const pains = [
  "大人数が一度に入れる店が、なかなか見つからない",
  "バスの駐車に困り、何度も動かす手間と費用がかさむ",
  "乗り降りのたびに時間を取られ、行程が押してしまう",
  "繁忙期は混雑で、予期せぬトラブルにも気を張りっぱなし",
];
---

<section class="scarcity l-section l-section--muted" id="scarcity">
  <div class="l-container">
    <header class="c-head c-head--left scarcity__head">
      <h2 class="c-head__title">
        団体昼食、立ち寄りの段取りに気を張っていませんか？
      </h2>
      <p class="c-head__lead">
        インバウンド需要が高まり、訪日観光客が増える影響で、まとまった人数が一度に入れる場所は年々見つけにくくなっています。場所探しだけでなく、当日の段取りにも気を遣うのが団体の手配です。
      </p>
    </header>

    <div class="scarcity__main">
      <!-- 痛みリスト（共感） -->
      <ul class="scarcity__pains">
        {
          pains.map((p) => (
            <li class="scarcity__pain">
              <span class="scarcity__pain-mark" aria-hidden="true" />
              <span class="scarcity__pain-text">{p}</span>
            </li>
          ))
        }
      </ul>

      <!-- 対比：混雑する観光地 → ひと組貸切の自社サイト -->
      <div class="scarcity__contrast">
        <figure class="scarcity__shot scarcity__shot--pain">
          <Image
            src={crowdBusy}
            alt="繁忙期に混雑する観光地の駐車場と人混み（イメージ）"
            width={1100}
            format="webp"
            loading="lazy"
          />
          <figcaption class="scarcity__cap scarcity__cap--pain">繁忙期は、どこも混雑</figcaption>
        </figure>

        <span class="scarcity__arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </span>

        <figure class="scarcity__shot scarcity__shot--relief">
          <Image
            src={privateLakeside}
            alt="西湖畔の貸切サイトに、ゆったり停まる大型バス"
            width={1100}
            format="webp"
            loading="lazy"
          />
          <figcaption class="scarcity__cap scarcity__cap--relief">貸切でノンストレス</figcaption>
        </figure>
      </div>
    </div>

    <!-- 転換＋リリーフ -->
    <div class="scarcity__relief">
      <p class="scarcity__relief-head">その段取りの悩み、いずみの湯が解決。</p>
      <p class="scarcity__relief-text">
        食事・温泉・お土産・休憩まで“この一か所”で完結。大型バス6台はそのまま停めて（駐車料込み）、乗り換えも移動もなし。数十名から250名規模まで、ひと組貸切で、自分たちのペースで。
      </p>

      <div class="scarcity__stats">
        <p class="scarcity__stats-note">他ではなかなか難しい規模を、ここで。</p>
        <ul class="scarcity__stats-list">
          <li class="scarcity__stat">
            <span class="scarcity__stat-value">
              <span class="scarcity__stat-pre">最大</span><span class="scarcity__stat-num">{SITE.capacityMax}</span><span class="scarcity__stat-unit">名</span>
            </span>
            <span class="scarcity__stat-label">完全貸切でお迎え</span>
          </li>
          <li class="scarcity__stat">
            <span class="scarcity__stat-value">
              <span class="scarcity__stat-num">{SITE.siteAreaSqm.toLocaleString()}</span><span class="scarcity__stat-unit">㎡</span>
            </span>
            <span class="scarcity__stat-label">貸切サイト</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @import "../../styles/variables";
  @import "../../styles/functions";
  @import "../../styles/mixins";

  .scarcity {
    color: var(--main_color_1);
  }

  .scarcity__head {
    margin-bottom: var(--space-5);
  }

  // 痛み＋対比：SP縦積み、desktopで2カラム
  .scarcity__main {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);

    @include desktop-up {
      flex-direction: row;
      align-items: center;
      gap: var(--space-6);

      > * {
        min-width: 0;
      }

      // 対比画像のカラムを痛みリストより広めにして、画像を大きく見せる
      .scarcity__pains {
        flex: 1 1 0;
      }
      .scarcity__contrast {
        flex: 1.4 1 0;
      }
    }
  }

  // ---- 痛みリスト ----
  .scarcity__pains {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  // 痛みカード：暖色を含む濃いめのグレー（チャコールブラウン）＋赤バーで「気がかり」を表現
  .scarcity__pain {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-3) var(--space-3) var(--space-4);
    background-color: #4a4340; // 暖色寄りのダークグレー（サイトの茶トーンに馴染ませる）
    border-left: 4px solid var(--accent-red); // 警告の赤バー
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--main_color_3); // クリームに反転
  }

  // 注意ドット（赤）＝“気がかり”の印
  .scarcity__pain-mark {
    flex-shrink: 0;
    width: 0.7em;
    height: 0.7em;
    margin-top: 0.55em;
    border-radius: var(--radius-pill);
    background-color: var(--accent-red);
  }

  // ---- 対比イメージ ----
  .scarcity__contrast {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);

    @include tablet-up {
      flex-direction: row;
      justify-content: center;
    }
  }

  .scarcity__shot {
    margin: 0;
    width: 100%;
    border-radius: var(--radius-card);
    overflow: clip;
    box-shadow: var(--shadow-soft);
    background-color: var(--white);

    img {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
    }
  }

  .scarcity__ph {
    border-radius: 0; // 親(scarcity__shot)で角丸＋clip
  }

  .scarcity__cap {
    display: block;
    padding: var(--space-1) var(--space-2);
    font-size: var(--fs-meta);
    font-weight: 700;
    text-align: center;
    white-space: nowrap; // 1行に収める
  }

  .scarcity__cap--pain {
    color: var(--accent-red);
  }

  .scarcity__cap--relief {
    color: var(--blue_1);
  }

  // 矢印：SPは下向き、tablet-upで右向き
  .scarcity__arrow {
    width: clamp(28px, 4vw, 44px);
    height: clamp(28px, 4vw, 44px);
    flex-shrink: 0;
    color: var(--main_color_1);
    transform: rotate(90deg);

    @include tablet-up {
      transform: none;
    }

    svg {
      display: block;
      width: 100%;
      height: 100%;
    }
  }

  // ---- 転換＋リリーフ ----
  .scarcity__relief {
    margin-top: var(--space-6);
    padding: var(--space-4);
    background-color: var(--white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);

    @include tablet-up {
      padding: var(--space-5);
    }
  }

  .scarcity__relief-head {
    font-size: var(--fs-h2);
    font-weight: 700;
    line-height: var(--lh-tight);
    margin-bottom: var(--space-3);
  }

  .scarcity__relief-text {
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
  }

  // ---- 数字（対比で希少性） ----
  .scarcity__stats {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(124, 99, 81, 0.15);
  }

  .scarcity__stats-note {
    font-size: var(--fs-meta);
    font-weight: 500;
    opacity: 0.85;
    margin-bottom: var(--space-2);
  }

  .scarcity__stats-list {
    display: flex;
    flex-direction: column; // SPは縦積み（横並びは幅に収まらないため）
    gap: var(--space-3);

    @include tablet-up {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-6);
    }
  }

  .scarcity__stat {
    text-align: center;

    @include tablet-up {
      flex: 0 0 auto;
    }
  }

  .scarcity__stat-value {
    display: flex;
    align-items: baseline;
    justify-content: center;
    white-space: nowrap; // 「最大250名」を1行に保つ（SPで折れないように）
  }

  // 「最大」など数字の前置き（小さめ）
  .scarcity__stat-pre {
    font-size: var(--fs-h3);
    font-weight: 700;
    margin-right: 0.15em;
  }

  .scarcity__stat-num {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1;
    color: var(--main_color_2); // 数字アクセント
  }

  .scarcity__stat-unit {
    font-size: var(--fs-h3);
    font-weight: 700;
  }

  .scarcity__stat-label {
    display: block;
    margin-top: var(--space-1);
    font-size: var(--fs-meta);
  }
</style>

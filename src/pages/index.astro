---
// いずみの湯 団体昼食LP（単独ページ）
import '../styles/main.scss';

import Head from '../components/layout/Head.astro';
import SiteHeader from '../components/layout/SiteHeader.astro';
import CtaBand from '../components/layout/CtaBand.astro';
import Footer from '../components/layout/Footer.astro';

import Hero from '../components/sections/Hero.astro';
import Scarcity from '../components/sections/Scarcity.astro';
import UseCases from '../components/sections/UseCases.astro';
import Reasons from '../components/sections/Reasons.astro';
import Venue from '../components/sections/Venue.astro';
import Menu from '../components/sections/Menu.astro';
import PlusAlpha from '../components/sections/PlusAlpha.astro';
import Onsen from '../components/sections/Onsen.astro';
import Pricing from '../components/sections/Pricing.astro';
import Downloads from '../components/sections/Downloads.astro';
import Access from '../components/sections/Access.astro';
import Faq from '../components/sections/Faq.astro';
import Contact from '../components/sections/Contact.astro';
---

<!doctype html>
<html lang="ja">
  <head>
    <Head />
  </head>
  <body>
    {/* サイト全体の固定背景（最背面）。各セクションは半透明でこの上にうっすら重なる */}
    <div class="page-bg" aria-hidden="true"></div>
    <SiteHeader />
    <main>
      <Hero />
      <Scarcity />
      <UseCases />
      <Reasons />
      <Venue />
      <Menu />
      <PlusAlpha />
      <Onsen />
      <CtaBand />
      <Pricing />
      <Downloads />
      <Access />
      <Faq />
      <Contact />
    </main>

    <Footer />
  </body>
</html>
